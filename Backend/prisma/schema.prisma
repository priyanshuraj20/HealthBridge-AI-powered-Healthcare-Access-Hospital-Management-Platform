datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String        @id @default(uuid())
  email        String        @unique
  passwordHash String
  role                 String        // "patient" | "org_admin" | "admin" | "receptionist" | "lab_tech"
  resetPasswordToken   String?
  resetPasswordExpire  DateTime?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  
  // Relations
  patient      Patient?
  organization Organization?
}

model Patient {
  id               String        @id @default(uuid())
  userId           String        @unique
  name             String
  phone            String?
  dob              DateTime?
  bloodGroup       String?
  allergies        String?
  emergencyContact String?       
  ayushmanCardNo   String?       
  ayushmanName     String?       
  ayushmanStatus   String        @default("Unverified") 
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  // Relations
  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  appointments     Appointment[]
  reports          Report[]
  familyMembers    FamilyMember[]
  reviews          Review[]
  medicalLoans     MedicalLoan[]
}

model FamilyMember {
  id          String    @id @default(uuid())
  patientId   String
  name        String
  relation    String    
  gender      String
  birthDate   DateTime
  createdAt   DateTime  @default(now())

  // Relations
  patient     Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

model Organization {
  id                 String     @id @default(uuid())
  userId             String     @unique
  name               String
  taxId              String     @unique
  verificationStatus String     @default("Pending") 
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  // Relations
  user               User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  hospitals          Hospital[]
}

model Hospital {
  id                  String          @id @default(uuid())
  organizationId      String
  name                String          @unique
  location            String          @default("Care City")
  locationHi          String?
  address             String?
  addressHi           String?
  city                String?
  cityHi              String?
  phone               String?
  licenseNumber       String?
  verificationStatus  String          @default("Pending") 
  distance            Float           @default(0.0)
  rating              Float           @default(4.5)
  waitingTime         Int             @default(30)
  specialties         String          // Comma-separated specialties list
  specialtiesHi       String?         // Comma-separated specialties list in Hindi
  supportedInsurances String          // Comma-separated accepted insurance list
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  // Relations
  organization        Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  beds                Bed[]
  treatmentCosts      TreatmentCost[]
  doctors             Doctor[]
  appointments        Appointment[]
  medicalLoans        MedicalLoan[]
}

model Bed {
  id         String   @id @default(uuid())
  hospitalId String
  type       String   // "icu" | "general" | "private" | "emergency"
  total      Int      @default(0)
  available  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  hospital   Hospital @relation(fields: [hospitalId], references: [id], onDelete: Cascade)
}

model TreatmentCost {
  id            String   @id @default(uuid())
  hospitalId    String
  treatmentName String
  cost          Float
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  hospital      Hospital @relation(fields: [hospitalId], references: [id], onDelete: Cascade)
}

model Doctor {
  id              String        @id @default(uuid())
  hospitalId      String
  name            String
  photoUrl        String?
  specialization  String
  qualification   String?
  experienceYears Int           @default(0)
  offlinePrice    Float         @default(500)
  onlinePrice     Float?
  isTelemedicine  Boolean       @default(false)
  rating          Float         @default(4.5)
  bio             String?
  email           String        @unique
  passwordHash    String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Relations
  hospital        Hospital      @relation(fields: [hospitalId], references: [id], onDelete: Cascade)
  slots           Slot[]
  appointments    Appointment[]
  reviews         Review[]
}

model Slot {
  id                    String   @id @default(uuid())
  doctorId              String
  dayOfWeek             String   
  startTime             String   
  endTime               String   
  slotDurationMinutes   Int      @default(30)
  createdAt             DateTime @default(now())

  // Relations
  doctor                Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)
}

model Appointment {
  id            String   @id @default(uuid())
  patientId     String
  doctorId      String
  hospitalId    String
  dateTime      DateTime
  mode          String   
  price         Float
  paymentStatus String   // "pending" | "paid" | "failed"
  status        String   // "upcoming" | "completed" | "cancelled"
  meetLink      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  patient       Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor        Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  hospital      Hospital @relation(fields: [hospitalId], references: [id], onDelete: Cascade)
  meetingRoom   Meeting?
}

model Meeting {
  id            String   @id @default(uuid())
  appointmentId String   @unique
  roomId        String
  token         String
  createdAt     DateTime @default(now())

  // Relations
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
}

model Report {
  id            String   @id @default(uuid())
  patientId     String
  appointmentId String?
  fileUrl       String
  aiSummary     String?
  uploadedAt    DateTime @default(now())

  // Relations
  patient       Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

model ContactMessage {
  id        String   @id @default(uuid())
  name      String
  email     String
  message   String
  createdAt DateTime @default(now())
}

model Review {
  id         String   @id @default(uuid())
  doctorId   String
  patientId  String
  reviewText String
  rating     Int
  createdAt  DateTime @default(now())

  // Relations
  doctor     Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  patient    Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

model MedicalLoan {
  id              String   @id @default(uuid())
  patientId       String
  hospitalId      String
  treatmentName   String
  requestedAmount Float
  tenureMonths    Int
  monthlyEMI      Float
  status          String   @default("pending") // "pending" | "approved" | "rejected"
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  patient         Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  hospital        Hospital @relation(fields: [hospitalId], references: [id], onDelete: Cascade)
}

# Server Configuration
PORT=5000

MONGO_URL=mongodb+srv://<username>:<password>@your_cluster.mongodb.net/HealthBridge?retryWrites=true&w=majority

# JWT Authentication
JWT_SECRET_KEY=your_jwt_secret_key_here

# Payment Settings (Stripe)
STRIPE_SECRET_KEY=sk_test_...

# Frontend URL Configuration (CORS & redirects)
CLIENT_SITE_URL=http://localhost:5173

OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=anthropic/claude-sonnet-4

# SMTP Email Configuration (Optional, falls back to console logging)
EMAIL_HOST=smtp.mailtrap.io
EMAIL_PORT=2525
EMAIL_USERNAME=your_smtp_username
EMAIL_PASSWORD=your_smtp_password

# Mailtrap Transactional API Keys (Alternative to SMTP)
MAILTRAP_TOKEN=6bc9abd243d7d2354faf9bc2c557f4ae
MAILTRAP_SENDER=hello@demomailtrap.co

